<%- include('../partials/header') %><!-- Include the shared header -->
<main>
  <h1>All Assignments</h1>
  <!-- Link to the Create Assignment page -->
  <a href="/assignments/new" class="btn">Add New Assignment</a>
  <!-- Table to display all assignments -->
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Description</th>
        <th>Due Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <!-- Loop through the list of assignments -->
      <% assignments.forEach(assignment => { %> 
        <tr>
          <td><%= assignment.title %></td>
          <td><%= assignment.description %></td>
          <td><%= assignment.dueDate.toDateString() %></td>
          <td>
            <a href="/assignments/<%= assignment._id %>/edit">Edit</a>
            <form action="/assignments/<%= assignment._id %>?_method=DELETE" method="POST" onsubmit="return confirmDelete();" style="display:inline;">
              <button type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</main>
<script>
  function confirmDelete() {
    return confirm('Are you sure you want to delete this assignment?');
  }
</script>
<%- include('../partials/footer') %> <!-- Include the shared footer -->
